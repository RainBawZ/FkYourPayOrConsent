{
    "manifest_version": 3,
    "name": "F*ck Your Pay-or-Consent",
    "version": "1.0.0",
    "description": "Removes Schibsted's Cookie 'Pay-or-Consent' overlays and restores page scrolling on selected sites.",
    "content_scripts": [
        {
            "matches": [
                "https://www.vg.no/*",
                "https://www.aftenposten.no/*",
                "https://www.e24.no/*",
                "https://www.tek.no/*",
                "https://www.bt.no/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_start"
        }
    ]
}
